{
  "expo": {
    "name": "Split",
    "slug": "Split",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D0D45"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.innova.split",
      "associatedDomains": ["applinks:mysplit.app"]
    },
    "android": {
      "package": "com.innova.split",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "mysplit.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "split",
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Split to use the camera to scan receipts and split bills."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Split to access your photos for receipts and your profile picture."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.split",
          "enableGooglePay": false
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Split to use Face ID to unlock the app."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Split to find which of your contacts are on mySplit."
        }
      ]
    ],
    "extra": {
      "receiptApiUrl": "http://localhost:8787"
    }
  }
}
