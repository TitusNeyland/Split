# Receipt parse API (Node server in /server). Use machine IP for physical device.
# Android emulator: http://10.0.2.2:8787
EXPO_PUBLIC_RECEIPT_API_URL=http://localhost:8787

# Stripe (PaymentSheet — publishable key; secret key stays on server only)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Firebase (profile photo → Storage users/{uid}/avatar.jpg, avatarUrl in Firestore users/{uid})
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
