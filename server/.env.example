OPENAI_API_KEY=sk-your-key-here
PORT=8787
# Optional override (default gpt-4o)
# OPENAI_VISION_MODEL=gpt-4o

# Stripe (PaymentMethod storage on Customer — never store full cards in Firestore)
STRIPE_SECRET_KEY=sk_test_...
# Firebase Admin JSON (same project as the app) to verify ID tokens on /api/stripe/*
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Local only: skip token verification; require x-firebase-uid header matching your test user
# STRIPE_DEV_BYPASS=1
