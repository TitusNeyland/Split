rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Friend system: friendships ---
    match /friendships/{friendshipId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.users;

      // Direct connect from Find People: deterministic doc id `uidSmall_uidLarge`, sorted `users`.
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['users', 'connectedAt', 'connectedVia', 'initiatedBy'])
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && request.resource.data.users[0] is string
        && request.resource.data.users[1] is string
        && request.resource.data.users[0] < request.resource.data.users[1]
        && request.auth.uid in request.resource.data.users
        && request.resource.data.initiatedBy == request.auth.uid
        && request.resource.data.connectedVia in ['search', 'contacts']
        && request.resource.data.connectedAt == request.time
        && friendshipId == request.resource.data.users[0] + '_' + request.resource.data.users[1];

      allow update: if false;

      allow delete: if request.auth != null
        && request.auth.uid in resource.data.users
        && resource.data.users is list
        && resource.data.users.size() == 2;
    }

    // --- Friend system: invites ---
    match /invites/{inviteId} {
      function inviteTargetedByEmail() {
        return resource.data.keys().hasAny(['recipientEmail'])
          && resource.data.recipientEmail is string
          && request.auth.token.email is string
          && resource.data.recipientEmail == request.auth.token.email.lower();
      }

      function inviteTargetedByPhone() {
        return resource.data.keys().hasAny(['recipientPhone'])
          && resource.data.recipientPhone is string
          && request.auth.token.keys().hasAny(['phone_hash'])
          && request.auth.token.phone_hash is string
          && resource.data.recipientPhone == request.auth.token.phone_hash;
      }

      function inviteOpenLink() {
        return (!resource.data.keys().hasAny(['recipientEmail'])
            || resource.data.recipientEmail == null
            || resource.data.recipientEmail == '')
          && (!resource.data.keys().hasAny(['recipientPhone'])
            || resource.data.recipientPhone == null
            || resource.data.recipientPhone == '');
      }

      allow read: if request.auth != null && (
        resource.data.createdBy == request.auth.uid
        || inviteTargetedByEmail()
        || inviteTargetedByPhone()
        || inviteOpenLink()
      );

      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.inviteId == inviteId
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['createdBy', 'inviteId', 'status', 'createdAt', 'expiresAt'])
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time;

      allow update: if request.auth != null
        && resource.data.status == 'pending'
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.inviteId == resource.data.inviteId
        && request.resource.data.expiresAt == resource.data.expiresAt
        && (
          (
            request.auth.uid == resource.data.createdBy
            && request.resource.data.status == 'expired'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          )
          || (
            request.auth.uid == resource.data.createdBy
            && request.resource.data.status == 'cancelled'
            && request.resource.data.cancelledAt is timestamp
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt'])
          )
          || (
            request.resource.data.status == 'accepted'
            && request.resource.data.acceptedBy == request.auth.uid
            && request.resource.data.acceptedAt is timestamp
            && resource.data.expiresAt > request.time
            && request.resource.data.acceptedBy != resource.data.createdBy
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'acceptedBy', 'acceptedAt'])
          )
          || (
            request.resource.data.status == 'declined'
            && request.resource.data.declinedBy == request.auth.uid
            && request.resource.data.declinedAt is timestamp
            && request.auth.uid != resource.data.createdBy
            && resource.data.expiresAt > request.time
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'declinedBy', 'declinedAt'])
          )
        );

      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // --- User profile + device sessions + address-book contacts ---
    match /users/{userId} {
      // Friend search queries `users` by displayNameLower / emailNormalized; readers must be allowed
      // to read other users' docs when discoverable (see lib/friends/userSearchFirestore.ts).
      // NOTE: This exposes the full user doc to other signed-in users; consider moving PII/payment
      // fields to a private subcollection later.
      function discoverableForUserSearch() {
        return (!resource.data.keys().hasAny(['discoverableByName']) || resource.data.discoverableByName != false)
          && (!resource.data.keys().hasAny(['privacySettings'])
            || !(resource.data.privacySettings is map)
            || !resource.data.privacySettings.keys().hasAny(['discoverableByName'])
            || resource.data.privacySettings.discoverableByName != false);
      }

      allow read: if request.auth != null
        && (
          request.auth.uid == userId
          || discoverableForUserSearch()
        );

      allow create, update, delete: if request.auth != null
        && request.auth.uid == userId;

      match /sessions/{sessionId} {
        allow read, create, update, delete: if request.auth != null
          && request.auth.uid == userId;
      }

      match /contacts/{contactId} {
        allow read, create, update, delete: if request.auth != null
          && request.auth.uid == userId;
      }

      /** In-app notifications (server writes); clients may mark read / split-invite outcome only. */
      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if false;
        allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'read',
            'actioned',
            'status',
            'cancelledAt',
          ]);
      }

      /**
       * Activity tab feed (server writes only). Clients read and may set `read`.
       * Path: users/{uid}/activity/{activityId}
       */
      match /activity/{activityId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if false;
        allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }
    }

    // --- Rest of app (align with client modules under lib/) ---
    match /subscriptions/{subscriptionId} {
      /** `memberUids` is the ACL list for array-contains queries. Legacy docs may use string[] `members`. */
      function subscriptionMemberData(data) {
        return (data.keys().hasAny(['memberUids']) && request.auth.uid in data.memberUids)
          || (data.keys().hasAny(['members']) && request.auth.uid in data.members);
      }

      allow read: if request.auth != null
        && subscriptionMemberData(resource.data);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid
        && subscriptionMemberData(request.resource.data);
      allow update, delete: if request.auth != null
        && subscriptionMemberData(resource.data);

      match /billing_cycles/{cycleId} {
        allow read, write: if request.auth != null
          && subscriptionMemberData(
            get(/databases/$(database)/documents/subscriptions/$(subscriptionId)).data
          );
      }

      match /split_change_log/{entryId} {
        allow read, write: if request.auth != null
          && subscriptionMemberData(
            get(/databases/$(database)/documents/subscriptions/$(subscriptionId)).data
          );
      }
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null && (
        resource.data.recipient == request.auth.uid
        || resource.data.payer == request.auth.uid
        || resource.data.owner == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.recipient == request.auth.uid
        || request.resource.data.payer == request.auth.uid
        || request.resource.data.owner == request.auth.uid
      );
      allow update, delete: if request.auth != null && (
        resource.data.recipient == request.auth.uid
        || resource.data.payer == request.auth.uid
        || resource.data.owner == request.auth.uid
      );
    }

    match /payment_intents/{intentId} {
      allow read: if request.auth != null && (
        resource.data.recipient == request.auth.uid
        || resource.data.payer == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.recipient == request.auth.uid
        || request.resource.data.payer == request.auth.uid
      );
      allow update, delete: if request.auth != null && (
        resource.data.recipient == request.auth.uid
        || resource.data.payer == request.auth.uid
      );
    }

    match /support_requests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /service_tiers/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Phone hash -> uid for contact discovery (owner may claim their hash).
    match /contact_phone_index/{hash} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.uid is string;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
